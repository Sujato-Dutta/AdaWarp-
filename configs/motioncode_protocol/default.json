    "NLinear",
    "PatchTST",
    "TimesNet",
    "iTransformer",
    "TimeMixer",
    "N-BEATS",
    "N-HiTS",
    "Autoformer",
    "FEDformer",
    "Informer"
  ],
  "repo_native_neural_baselines": [
    "DLinear",
    "NLinear",
    "PatchTST",
    "TimesNet",
    "iTransformer",
    "TimeMixer",
    "N-BEATS",
    "N-HiTS",
    "VPNet",
    "Autoformer",
    "FEDformer",
    "Informer",
    "ETSformer",
    "Pyraformer"
  ],
  "external_required_neural_baselines": [],
