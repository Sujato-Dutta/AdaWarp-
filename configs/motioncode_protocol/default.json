{
  "name": "AdaWarp matched Motion Code prefix-to-suffix protocol",
  "method_name": "AdaWarp",
  "datasets": [
    "PronunciationAudio",
    "ECGFiveDays",
    "FreezerSmallTrain",
    "HouseTwenty",
    "InsectEPGRegularTrain",
    "ItalyPowerDemand",
    "Lightning7",
